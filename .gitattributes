# Normalise line endings: LF in the repo, native in the working tree.
* text=auto eol=lf

# Windows-only scripts stay CRLF.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Treat known binary assets as binary (no EOL conversion, no diff).
*.png binary
*.jpg binary
*.ico binary
*.gif binary
*.zip binary
*.dat binary
